<robot name="wheel_leg">

  <!-- 这部分是urdf的连杆关节描述 -->
  <!-- link -->
  <link name="base_link">
    <inertial>
      <origin xyz="0.01131 -0.0013618 -0.00028518" rpy="0 0 0" />
      <mass value="2.9637" />
      <!-- <mass value="10.9637" /> -->
      <inertia ixx="0.032877" ixy="7.66E-06" ixz="0.0013225" iyy="0.022941" iyz="-1.903E-05" izz="0.041458" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://description/meshes/base_link.STL" />
      </geometry>
      <material name="">
        <color rgba="1 1 1 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://description/meshes/base_link.STL" />
      </geometry>
    </collision>
  </link>

  <link name="R1_link">
    <inertial>
      <origin xyz="0.020031 0.0032153 0.0036019" rpy="0 0 0" />
      <mass value="0.51378" />
      <inertia ixx="0.00053799" ixy="-3.71E-05" ixz="-0.00023837" iyy="0.0015906" iyz="-3.414E-05" izz="0.0015943" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://description/meshes/R1_link.STL" />
      </geometry>
      <material name="">
        <color rgba="1 1 1 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://description/meshes/R1_link.STL" />
      </geometry>
    </collision>
  </link>

  <link name="R2_link">
    <inertial>
      <origin xyz="0.072881 0.034135 0.019602" rpy="0 0 0" />
      <mass value="0.27188" />
      <inertia ixx="0.00060818" ixy="-0.00045096" ixz="-0.00016097" iyy="0.0018646" iyz="0.00017552" izz="0.0022898" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://description/meshes/R2_link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://description/meshes/R2_link.STL" />
      </geometry>
    </collision>
  </link>

  <link name="R3_link">
    <inertial>
      <origin xyz="3.3998E-05 -2.1315E-05 0.046652" rpy="0 0 0" />
      <mass value="1.3401" />
      <inertia ixx="0.0034313" ixy="1.05E-06" ixz="3.9E-07" iyy="0.0034305" iyz="-3.7E-07" izz="0.0062845" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://description/meshes/R3_link.STL" />
      </geometry>
      <material name="">
        <color rgba="1 1 1 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://description/meshes/R3_link.STL" />
      </geometry>
    </collision>
  </link>

  <link name="L1_link">
    <inertial>
      <origin xyz="0.019888 -0.0032269 0.0036874" rpy="0 0 0" />
      <mass value="0.51183" />
      <inertia ixx="0.00053571" ixy="3.735E-05" ixz="-0.00023627" iyy="0.0015772" iyz="3.397E-05" izz="0.0015814" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://description/meshes/L1_link.STL" />
      </geometry>
      <material name="">
        <color rgba="1 1 1 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://description/meshes/L1_link.STL" />
      </geometry>
    </collision>
  </link>

  <link name="L2_link">
    <inertial>
      <origin xyz="0.073104 -0.034096 0.019634" rpy="0 0 0" />
      <mass value="0.27057" />
      <inertia ixx="0.00060605" ixy="0.00044968" ixz="-0.00016124" iyy="0.0018598" iyz="-0.00017532" izz="0.0022833" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://description/meshes/L2_link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://description/meshes/L2_link.STL" />
      </geometry>
    </collision>
  </link>

  <link name="L3_link">
    <inertial>
      <origin xyz="-1.783E-05 -3.5948E-05 0.046652" rpy="0 0 0" />
      <mass value="1.3401" />
      <inertia ixx="0.0034303" ixy="-9.5E-07" ixz="-3.3E-07" iyy="0.0034315" iyz="-4.2E-07" izz="0.0062845" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://description/meshes/L3_link.STL" />
      </geometry>
      <material name="">
        <color rgba="1 1 1 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://description/meshes/L3_link.STL" />
      </geometry>
    </collision>
  </link>

  <!-- joint -->
  <joint name="R1_joint" type="revolute">
    <origin xyz="-0.001 -0.1785 -0.025" rpy="1.5708 0.34907 0" />
    <parent link="base_link" />
    <child link="R1_link" />
    <axis xyz="0 0 1" />
    <limit lower="-300.14" upper="300.14" effort="10000" velocity="6.5" />
    <!-- wbc -->
    <dynamics damping="2" friction="1" />
    <!-- vmc -->
    <!-- <dynamics damping="0.1" friction="0.05" /> -->
    <!-- <dynamics damping="0.05" friction="0.05" /> -->
  </joint>

  <joint name="R2_joint" type="revolute">
    <origin xyz="0.15 0 0" rpy="0 0 -1.6581" />
    <parent link="R1_link" />
    <child link="R2_link" />
    <axis xyz="0 0 1" />
    <limit lower="-300.14" upper="300.14" effort="10000" velocity="6.5" />
    <!-- <dynamics damping="1" friction="1" /> -->
    <dynamics damping="2" friction="1" />
    <!-- <dynamics damping="0.05" friction="0.05" /> -->
  </joint>

  <joint name="R3_joint" type="continuous">
    <origin xyz="0.25 0 0" rpy="0 0 2.0071" />
    <parent link="R2_link" />
    <child link="R3_link" />
    <axis xyz="0 0 1" />
    <limit effort="10000" velocity="500" />
    <dynamics damping="0" friction="0.0" />
  </joint>

  <joint name="L1_joint" type="revolute">
    <origin xyz="-0.00099957 0.1765 -0.024999" rpy="-1.5708 0.34907 0" />
    <parent link="base_link" />
    <child link="L1_link" />
    <axis xyz="0 0 1" />
    <limit lower="-300.14" upper="300.14" effort="10000" velocity="6.5" />
    <dynamics damping="2" friction="1" />
    <!-- <dynamics damping="0.1" friction="0.05" /> -->
    <!-- <dynamics damping="0.05" friction="0.05" /> -->
  </joint>

  <joint name="L2_joint" type="revolute">
    <origin xyz="0.15 0 0" rpy="0 0 1.6581" />
    <parent link="L1_link" />
    <child link="L2_link" />
    <axis xyz="0 0 1" />
    <limit lower="-300.14" upper="300.14" effort="10000" velocity="6.5" />
    <!-- <dynamics damping="1" friction="1" /> -->
    <dynamics damping="2" friction="1" />
    <!-- <dynamics damping="0.05" friction="0.05" /> -->
  </joint>

  <joint name="L3_joint" type="continuous">
    <origin xyz="0.25 0 0" rpy="0 0 -2.0071" />
    <parent link="L2_link" />
    <child link="L3_link" />
    <axis xyz="0 0 1" />
    <limit effort="10000" velocity="500" />
    <dynamics damping="0" friction="0.0" />
  </joint>
  <!-- <kenematic>=1表示base_link只进行运动学计算，不涉及运动学(这里可以固定连杆，在gazebo中可手动拖动连杆) -->
  <!-- <gazebo reference="base_link">
    <kinematic>1</kinematic>
  </gazebo> -->
  <!-- <gazebo reference="L2_link">
    <kinematic>1</kinematic>
  </gazebo>
  <gazebo reference="R2_link">
    <kinematic>1</kinematic>
  </gazebo> -->
  
    <!-- 加载控制器插件，并提供命名空间 -->
    <gazebo>
      <plugin name="gazebo_ros_control" filename="libgazebo_ros_control.so">
        <robotNamespace>/wheel_leg</robotNamespace>
      </plugin>
    </gazebo>
  
    <!-- 必需：添加gazebo标签为各个link添加颜色 -->
    <gazebo reference="base_link">
      <material>Gazebo/Yellow</material>
    </gazebo>
    <gazebo reference="L1_link">
      <material>Gazebo/Yellow</material>
    </gazebo>
    <gazebo reference="L2_link">
      <material>Gazebo/Yellow</material>
    </gazebo>
    <gazebo reference="L3_link">
      <material>Gazebo/Yellow</material>
    </gazebo>
    <gazebo reference="R1_link">
      <material>Gazebo/Yellow</material>
    </gazebo>
    <gazebo reference="R2_link">
      <material>Gazebo/Yellow</material>
    </gazebo>
    <gazebo reference="R3_link">
      <material>Gazebo/Yellow</material>
    </gazebo>
  
    <!-- 为各个关节添加传动装置以及电机 -->
    <transmission name="tran1">
      <type>transmission_interface/SimpleTransmission</type>
      <joint name="R1_joint">
        <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      </joint>
      <actuator name="motor1">
        <mechanicalReduction>50</mechanicalReduction>
        <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      </actuator>
    </transmission>
  
    <transmission name="tran2">
      <type>transmission_interface/SimpleTransmission</type>
      <joint name="R2_joint">
        <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      </joint>
      <actuator name="motor2">
        <mechanicalReduction>50</mechanicalReduction>
        <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      </actuator>
    </transmission>
  
    <transmission name="tran3">
      <type>transmission_interface/SimpleTransmission</type>
      <joint name="R3_joint">
        <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      </joint>
      <actuator name="motor3">
        <mechanicalReduction>50</mechanicalReduction>
        <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      </actuator>
    </transmission>
  
    <transmission name="tran4">
      <type>transmission_interface/SimpleTransmission</type>
      <joint name="L1_joint">
        <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      </joint>
      <actuator name="motor4">
        <mechanicalReduction>50</mechanicalReduction>
        <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      </actuator>
    </transmission>
  
    <transmission name="tran5">
      <type>transmission_interface/SimpleTransmission</type>
      <joint name="L2_joint">
        <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      </joint>
      <actuator name="motor5">
        <mechanicalReduction>50</mechanicalReduction>
        <hardwareInterface>EffortJointInterface</hardwareInterface>
      </actuator>
    </transmission>
  
    <transmission name="tran6">
      <type>transmission_interface/SimpleTransmission</type>
      <joint name="L3_joint">
        <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      </joint>
      <actuator name="motor6">
        <mechanicalReduction>50</mechanicalReduction>
        <hardwareInterface>EffortJointInterface</hardwareInterface>
      </actuator>
    </transmission>
  
  
    <!-- 设置gazebo摩擦系数：mu1为静摩擦系数，mu2为动摩擦系数 -->
    <gazebo reference="base_link">
      <mu>0.5</mu>
      <mu2>0.5</mu2>
    </gazebo>
    <gazebo reference="R1_link">
      <mu>0.5</mu>
      <mu2>0.5</mu2>
    </gazebo>
    <gazebo reference="R2_link">
      <mu>0.5</mu>
      <mu2>0.5</mu2>
    </gazebo>
    <gazebo reference="R3_link">
      <mu>1.2</mu>
      <mu2>1.2</mu2>
      <!-- 以下为L1用 -->
      <!-- <mu>0.8</mu>
      <mu2>0.8</mu2> -->
      <kp>10000</kp>
      <kd>1000</kd>
    </gazebo>

    <gazebo reference="L1_link">
      <mu>0.5</mu>
      <mu2>0.5</mu2>
    </gazebo>
    <gazebo reference="L2_link">
      <mu>0.5</mu> 
      <mu2>0.5</mu2> 
    </gazebo>
    <gazebo reference="L3_link">
      <mu>1.2</mu>
      <mu2>1.2</mu2>     
      <!-- <mu>0.8</mu>
      <mu2>0.8</mu2> -->
      <kp>10000</kp>
      <kd>1000</kd>
    </gazebo>

  
  
  
  
    <!-- 以下为传感器插件的导入 -->
    <!-- 加入imu插件到base_link上 -->
    <!-- 第一种imu -->
    <gazebo reference="base_link">
      <gravity>true</gravity>
      <sensor name="imu_sensor" type="imu">
        <always_on>true</always_on>
        <update_rate>500</update_rate>
        <visualize>true</visualize>
        <topic>__default_topic__</topic>
        <plugin filename="libgazebo_ros_imu_sensor.so" name="imu_plugin">
          <!--发布的话题名称-->
          <topicName>/wheel_leg/imu</topicName>
          <bodyName>base_link</bodyName>
          <!--更新频率-->
          <updateRateHZ>500.0</updateRateHZ>
          <!--高斯噪声-->
          <gaussianNoise>0.0</gaussianNoise>
          <xyzOffset>0 0 0</xyzOffset>
          <rpyOffset>0 0 0</rpyOffset>
          <frameName>imu_link</frameName>
          <initialOrientationAsReference>false</initialOrientationAsReference>
        </plugin>
        <pose>0 0 0 0 0 0</pose>
      </sensor>
    </gazebo>
    <!-- 第二种imu -->
    <!-- <gazebo reference="base_link">
      <plugin filename="libgazebo_ros_imu.so" name="imu_plugin">
        <alwaysOn>true</alwaysOn>
        <bodyName>main_base</bodyName>
        <updateRate>50</updateRate>
        <serviceName>/wheel_leg/imu_service</serviceName>
        <topicName>/bbot/imu</topicName>
        <gaussianNoise>0</gaussianNoise>
        <xyzOffset>0 0 0</xyzOffset>
        <rpyOffset>0 0 0</rpyOffset>
      </plugin>     
    </gazebo>  -->
  
    <!-- model 控制:使用geometry_msgs /Twist类型消息控制gazebo任意模型沿水平面移动（link、joint），尝试了一下，发现会影响仿真速度！！ -->
    <!-- <gazebo>
      <plugin name="object_controller" filename="libgazebo_ros_planar_move.so">
        <commandTopic>cmd_vel</commandTopic>
        <odometryTopic>odom</odometryTopic>
        <odometryFrame>odom</odometryFrame>
        <odometryRate>10.0</odometryRate>
        <robotBaseFrame>base_link</robotBaseFrame>
        <cmdTimeout>0.5</cmdTimeout>
      </plugin>
    </gazebo> -->
  
    <!-- 轮子里程计 -->
    <gazebo>
      <plugin name="p3d_base_controller" filename="libgazebo_ros_p3d.so">
        <alwaysOn>true</alwaysOn>
        <updateRate>500.0</updateRate>
        <!-- <bodyName>base_link</bodyName> -->
        <bodyName>L3_link</bodyName>
        <topicName>/wheel_leg/odom</topicName>
        <gaussianNoise>0.00</gaussianNoise>
        <frameName>world</frameName>
        <xyzOffsets>0 0 0</xyzOffsets>
        <rpyOffsets>0 0 0</rpyOffsets>
      </plugin>
    </gazebo>  



  <gazebo>
  <plugin name="p3d_base_controller_base" filename="libgazebo_ros_p3d.so">
    <alwaysOn>true</alwaysOn>
    <updateRate>500.0</updateRate>
    <bodyName>base_link</bodyName>   <!-- 换成你基座的link名字 -->
    <topicName>/wheel_leg/odom_base</topicName>  <!-- 换个topic名字 -->
    <gaussianNoise>0.00</gaussianNoise>
    <frameName>world</frameName>
    <xyzOffsets>0 0 0</xyzOffsets>
    <rpyOffsets>0 0 0</rpyOffsets>
  </plugin>
</gazebo>

    
    


</robot>